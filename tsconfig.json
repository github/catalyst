{
  "include": ["src", "test"],
  "exclude": ["node_modules"],
  "compilerOptions": {
    "baseUrl": ".",
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "lib": ["es2020", "dom", "dom.iterable"],
    "module": "ESNext",
    "moduleResolution": "node",
    "noEmit": true,
    "sourceMap": true,
    "strict": true,
    "target": "ES2020",
    "types": ["vitest/globals"],
    "skipLibCheck": true
  }
}
